# ARK: Survival Evolved server configuration.
# Copy this file to `.env` and edit that copy — `.env` is gitignored and
# overrides the defaults below. You never edit install.sh.
#
#   cp .env.example .env

# Name shown in the server browser.
SESSION_NAME="My ARK Server"

# Leave empty for an open server (avoid ? and spaces in ARK values).
SERVER_PASSWORD=""

# Leave empty to auto-generate a strong admin password (printed at the end).
ADMIN_PASSWORD=""

# Player cap — ARK default is 70; size to your RAM.
MAX_PLAYERS="70"

# Map: TheIsland, ScorchedEarth_P, Ragnarok, Aberration_P, Extinction, etc.
MAP="TheIsland"

# UDP game port and Steam query port (server browser).
GAME_PORT="7777"
QUERY_PORT="27015"

# Install location and the unprivileged user the server runs as.
SVC_USER="arkse"
BASE_DIR="/opt/ark-se"
