# Palworld server configuration.
# Copy this file to `.env` and edit that copy — `.env` is gitignored and
# overrides the defaults below. You never edit install.sh.
#
#   cp .env.example .env
#
# Values are read literally, so $, !, quotes and other symbols (e.g. in
# passwords) are fine. Wrap a value in quotes if it contains spaces.

# Name shown to players (avoid the " character).
SERVER_NAME="My Palworld 1.0 Server"
SERVER_DESCRIPTION="Palworld dedicated server"

# Leave empty for an open server.
SERVER_PASSWORD=""

# Leave empty to auto-generate a strong admin password (printed at the end).
ADMIN_PASSWORD=""

# Max players — 16 GB RAM recommended for a full server.
MAX_PLAYERS="32"

# UDP game port. Must be reachable from the internet.
GAME_PORT="8211"

# true = disable raid events (less memory-leak pressure, but no invaders).
DISABLE_INVADERS="false"

# Install location and the unprivileged user the server runs as.
SVC_USER="palworld"
BASE_DIR="/opt/palworld"
